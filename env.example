# Copy this to .env (local dev) or set these in your deployment platform (Plesk custom variables, Nhost Run env, etc.)

# ---------------------------------------------------------------------------
# Hasura — set ONE of the following:
# ---------------------------------------------------------------------------
# Full GraphQL endpoint (preferred for standalone deploys):
HASURA_GRAPHQL_URL=https://xxx.nhost.run/v1/graphql
# OR base Nhost URL (the server appends /v1/graphql automatically):
# NHOST_HASURA_URL=https://xxx.nhost.run

HASURA_GRAPHQL_ADMIN_SECRET=replace-me

# ---------------------------------------------------------------------------
# Nhost Auth — set ONE of the following:
# ---------------------------------------------------------------------------
# Full auth URL:
NHOST_AUTH_URL=https://xxx.auth.ap-southeast-1.nhost.run
# OR subdomain + region (derive auth URL automatically):
# NHOST_SUBDOMAIN=xxx
# NHOST_REGION=ap-southeast-1

# ---------------------------------------------------------------------------
# Upstash Redis (required — used for caching and rate limiting)
# ---------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace-me

# ---------------------------------------------------------------------------
# S3 (required for image uploads)
# ---------------------------------------------------------------------------
S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-me
S3_REGION=ap-northeast-2
S3_BUCKET_NAME=replace-me
# S3_BUCKET_DOMAIN=replace-me  # optional, defaults to <bucket>.s3.<region>.amazonaws.com

# ---------------------------------------------------------------------------
# Image processing (optional — defaults shown)
# ---------------------------------------------------------------------------
IMAGE_MAX_WIDTH=1600
IMAGE_MAX_HEIGHT=1600
IMAGE_AVIF_QUALITY=60
IMAGE_WEBP_QUALITY=75

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
PORT=3000
# CORS_ORIGIN=https://yourdomain.com  # optional, defaults to * (open)
NODE_ENV=development

# ---------------------------------------------------------------------------
# App URL (used as Referer in Google photo proxy)
# ---------------------------------------------------------------------------
APP_URL=http://localhost:3000
